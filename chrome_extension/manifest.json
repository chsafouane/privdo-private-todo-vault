{
  "manifest_version": 3,
  "name": "Privdo",
  "description": "Private todo lists encrypted on your device. PIN-locked lists with deadlines, drag & drop, and optional encrypted sync.",
  "version": "1.0.5",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "pwa-192x192.png",
      "48": "pwa-192x192.png",
      "128": "pwa-512x512.png"
    }
  },
  "icons": {
    "16": "pwa-192x192.png",
    "48": "pwa-192x192.png",
    "128": "pwa-512x512.png"
  },
  "permissions": ["storage"]
}
